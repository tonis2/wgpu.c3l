{
	"langrev": "1",
	"warnings": ["no-unused"],
	"version": "0.1.0",
	"targets": {
		"build": {
			"type": "executable",
			"sources": ["./parser/*"]
		},
		"cube_web": {
			"type": "executable",
			"sources": ["examples/cube/main_web.c3", "lib/*"],
			"target": "wasm32",
			"link-libc": false,
			"reloc": "none",
			"debug-info": "none",
			"no-entry": true,
			"output": "examples/cube/web"
		},
		"cube": {
			"type": "executable",
			"sources": ["examples/cube/main.c3", "lib/*"],
			"dependencies": ["c3w"],
			"dependency-search-paths": [".", "./libs"],
			"linked-libraries": ["wgpu_native"],
			"linker-search-paths": ["./libs/wgpu-native/lib"],
			"link-args": ["-Wl,-rpath,\\$ORIGIN/../libs/wgpu-native/lib"]
		},
		"zip": {
			"type": "prepare",
			"exec": ["zip -r webgpu.c3l ./lib manifest.json"]
		}
	},
	"output": "./build"
}
